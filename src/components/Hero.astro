---
---
<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden" style="background: radial-gradient(ellipse at 70% 50%, #134023 0%, #0d2b1a 40%, #0a1f13 100%);">

  <div class="absolute inset-0 gold-grid pointer-events-none"></div>

  <div class="absolute top-1/4 right-1/4 w-96 h-96 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(201,149,42,0.08) 0%, transparent 70%); filter: blur(40px);"></div>
  <div class="absolute bottom-1/3 left-1/3 w-64 h-64 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(19,64,35,0.4) 0%, transparent 70%); filter: blur(60px);"></div>

  <div class="relative z-10 w-full max-w-5xl mx-auto px-5 sm:px-8 lg:px-12 pt-28 sm:pt-32 pb-16 flex flex-col items-center text-center">

    <div id="hero-label" class="section-label mb-6 gsap-hidden">
      Study Abroad, The Easy Way
    </div>

    <h1 class="section-heading mb-6 w-full">
      <span id="hero-line1" class="block fluid-4xl gsap-hidden" style="clip-path: inset(0 0 100% 0)">Your Dream of</span>
      <span id="hero-line2" class="block fluid-4xl gold-text gsap-hidden" style="clip-path: inset(0 0 100% 0)">Studying Abroad</span>
      <span id="hero-line3" class="block fluid-4xl gsap-hidden" style="clip-path: inset(0 0 100% 0)">Starts Here</span>
    </h1>

    <p id="hero-sub" class="fluid-base text-white/70 max-w-2xl leading-relaxed mb-8 gsap-hidden">
      Your gateway to <strong class="text-white/90">Master's admission</strong> in the
      <strong class="text-white/90">UK and Canada</strong> — with personalised guidance,
      end-to-end support, and our exclusive <strong class="text-brand-gold-500">Study Now, Pay Later</strong> tuition loan.
      Zero collateral. Zero guarantor.
    </p>

    <div id="hero-ctas" class="flex flex-col sm:flex-row gap-4 mb-10 gsap-hidden">
      <a href="#contact" class="btn-primary text-sm sm:text-base px-6 sm:px-8">Start Your Application</a>
      <a href="#about" class="btn-outline text-sm sm:text-base px-6 sm:px-8">Learn More</a>
    </div>

    <div id="hero-pills" class="flex flex-wrap justify-center gap-3 mb-12 gsap-hidden">
      <span class="glass-card rounded-full px-4 py-2 text-xs sm:text-sm text-white/80 flex items-center gap-2">🇬🇧 United Kingdom</span>
      <span class="glass-card rounded-full px-4 py-2 text-xs sm:text-sm text-white/80 flex items-center gap-2">🇨🇦 Canada</span>
      <span class="glass-card rounded-full px-4 py-2 text-xs sm:text-sm text-brand-gold-500 flex items-center gap-2 border border-brand-gold-500/30">✦ Master's Only</span>
    </div>

    <div id="hero-video-block" class="w-full max-w-xl gsap-hidden">
      <div
        id="video-trigger"
        class="relative rounded-2xl overflow-hidden cursor-pointer group"
        style="background: linear-gradient(135deg, #134023 0%, #0a1f13 100%); aspect-ratio: 16/9; border: 1px solid rgba(201,149,42,0.2);"
        role="button"
        aria-label="Play video"
        tabindex="0"
      >
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="relative flex items-center justify-center mb-3">
            <span class="absolute inline-flex w-16 h-16 rounded-full opacity-40" style="background: rgba(201,149,42,0.3); animation: pingGold 2s cubic-bezier(0,0,0.2,1) infinite;"></span>
            <div class="relative z-10 w-14 h-14 rounded-full flex items-center justify-center border-2 border-brand-gold-500 group-hover:scale-110 transition-transform duration-300" style="background: rgba(201,149,42,0.15);">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M6 4l12 6-12 6V4z" fill="#c9952a"/>
              </svg>
            </div>
          </div>
          <span class="text-white/60 text-xs tracking-widest uppercase font-inter">Watch Our Story</span>
        </div>
        <div class="absolute top-3 left-3 w-6 h-6 border-t border-l border-brand-gold-500/30 rounded-tl"></div>
        <div class="absolute top-3 right-3 w-6 h-6 border-t border-r border-brand-gold-500/30 rounded-tr"></div>
        <div class="absolute bottom-3 left-3 w-6 h-6 border-b border-l border-brand-gold-500/30 rounded-bl"></div>
        <div class="absolute bottom-3 right-3 w-6 h-6 border-b border-r border-brand-gold-500/30 rounded-br"></div>
      </div>
    </div>

    <div id="scroll-indicator" class="mt-10 flex flex-col items-center gap-2 gsap-hidden">
      <span class="text-white/30 text-xs tracking-widest uppercase font-inter">Scroll to explore</span>
      <div class="w-5 h-8 border border-white/20 rounded-full flex items-start justify-center p-1">
        <div class="w-1 h-2 bg-brand-gold-500/60 rounded-full" style="animation: bounceSlow 2s ease-in-out infinite;"></div>
      </div>
    </div>
  </div>
</section>

<div id="video-lightbox" role="dialog" aria-modal="true" aria-label="Video player">
  <div id="lightbox-backdrop" class="absolute inset-0"></div>
  <div id="lightbox-inner" class="relative z-10 w-full max-w-4xl mx-4" style="transform: scale(0.8); opacity: 0;">
    <button id="lightbox-close" aria-label="Close video" class="absolute -top-10 right-0 text-white/70 hover:text-white flex items-center gap-2 text-sm font-inter transition-colors">
      <span>Close</span>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M2 2L16 16M16 2L2 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="rounded-xl overflow-hidden" style="aspect-ratio: 16/9; background:#000;">
      <video
        id="hero-video"
        src="https://res.cloudinary.com/dx3k7hbnc/video/upload/q_auto/f_auto/v1780761104/Admitwithease_Hero_p0xtxi.mp4"
        preload="none"
        controls
        playsinline
        class="w-full h-full object-contain"
      ></video>
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ delay: 0.3 });

  tl.to('#hero-label', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
    .to('#hero-line1', { clipPath: 'inset(0 0 0% 0)', opacity: 1, duration: 0.7, ease: 'power3.out' }, '-=0.2')
    .to('#hero-line2', { clipPath: 'inset(0 0 0% 0)', opacity: 1, duration: 0.7, ease: 'power3.out' }, '-=0.5')
    .to('#hero-line3', { clipPath: 'inset(0 0 0% 0)', opacity: 1, duration: 0.7, ease: 'power3.out' }, '-=0.5')
    .to('#hero-sub', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.3')
    .to('#hero-ctas', { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.3')
    .to('#hero-pills', { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.2')
    .to('#hero-video-block', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.2')
    .to('#scroll-indicator', { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.2');

  const lightbox = document.getElementById('video-lightbox')!;
  const lightboxInner = document.getElementById('lightbox-inner')!;
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  const videoTrigger = document.getElementById('video-trigger')!;
  const closeBtn = document.getElementById('lightbox-close')!;
  const backdrop = document.getElementById('lightbox-backdrop')!;

  function openLightbox() {
    lightbox.classList.add('active');
    gsap.to(lightboxInner, { scale: 1, opacity: 1, duration: 0.4, ease: 'power3.out' });
    video.play().catch(() => {});
  }

  function closeLightbox() {
    gsap.to(lightboxInner, {
      scale: 0.85, opacity: 0, duration: 0.3, ease: 'power2.in',
      onComplete: () => {
        lightbox.classList.remove('active');
        video.pause();
        video.currentTime = 0;
      }
    });
  }

  videoTrigger.addEventListener('click', openLightbox);
  videoTrigger.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') openLightbox(); });
  closeBtn.addEventListener('click', closeLightbox);
  backdrop.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('active')) closeLightbox();
  });
</script>