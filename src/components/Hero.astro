---
const videoUrl = "https://res.cloudinary.com/dx3k7hbnc/video/upload/q_auto/f_auto/v1780761104/Admitwithease_Hero_p0xtxi.mp4";
---

<!-- HERO SECTION -->
<section
  id="home"
  class="relative min-h-screen w-full flex items-center justify-center overflow-hidden gradient-hero"
>

  <!-- Background decorative orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full
              bg-brand-gold-500/5 blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full
              bg-brand-green-600/20 blur-[100px] pointer-events-none"></div>

  <!-- Subtle grid overlay -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.03]"
    style="background-image: linear-gradient(rgba(201,149,42,0.5) 1px, transparent 1px),
           linear-gradient(90deg, rgba(201,149,42,0.5) 1px, transparent 1px);
           background-size: 60px 60px;"
  ></div>

  <!-- HERO CONTENT -->
  <div class="relative z-10 section-padding w-full pt-24 pb-16
              flex flex-col items-center text-center gap-8 md:gap-10">

    <!-- Label -->
    <div
      id="hero-label"
      class="gsap-fade-in flex items-center gap-3"
    >
      <div class="w-8 h-[1px] bg-brand-gold-500"></div>
      <span class="section-label mb-0">Study Abroad, The Easy Way</span>
      <div class="w-8 h-[1px] bg-brand-gold-500"></div>
    </div>

    <!-- Headline -->
    <div class="flex flex-col items-center gap-2 md:gap-3">
      <div class="gsap-line-reveal">
        <span
          id="hero-line-1"
          class="block font-heading text-fluid-3xl md:text-fluid-4xl
                 text-white font-semibold leading-tight tracking-tight"
        >
          Your Dream of
        </span>
      </div>
      <div class="gsap-line-reveal">
        <span
          id="hero-line-2"
          class="block font-heading text-fluid-3xl md:text-fluid-4xl
                 font-semibold leading-tight tracking-tight gold-gradient"
        >
          Studying Abroad
        </span>
      </div>
      <div class="gsap-line-reveal">
        <span
          id="hero-line-3"
          class="block font-heading text-fluid-3xl md:text-fluid-4xl
                 text-white font-semibold leading-tight tracking-tight"
        >
          Starts Here
        </span>
      </div>
    </div>

    <!-- Subtext -->
    <p
      id="hero-sub"
      class="gsap-fade-up section-subtext text-center mx-auto
             max-w-xs sm:max-w-md md:max-w-xl lg:max-w-2xl"
    >
      We help ambitious Nigerian students secure
      <span class="text-brand-gold-400 font-medium">Master's admission</span>
      in the UK and Canada — with tuition loan support,
      <span class="text-brand-gold-400 font-medium">zero collateral</span>,
      and zero stress.
    </p>

    <!-- CTA Buttons -->
    <div
      id="hero-ctas"
      class="gsap-fade-up flex flex-col sm:flex-row items-center
             gap-4 sm:gap-5 w-full sm:w-auto"
    >
      <a href="#contact" class="btn-primary w-full sm:w-auto text-sm md:text-base px-7 py-3.5">
        Start Your Application
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="#about" class="btn-outline w-full sm:w-auto text-sm md:text-base px-7 py-3.5">
        Learn More
      </a>
    </div>

    <!-- Destination Pills -->
    <div
      id="hero-pills"
      class="gsap-fade-up flex items-center gap-3 flex-wrap justify-center"
    >
      <div class="flex items-center gap-2 card-glass rounded-full px-4 py-2">
        <span class="text-base leading-none">🇬🇧</span>
        <span class="font-body text-xs font-medium text-white/80 tracking-wide">
          United Kingdom
        </span>
      </div>
      <div class="w-1 h-1 rounded-full bg-brand-gold-500/50"></div>
      <div class="flex items-center gap-2 card-glass rounded-full px-4 py-2">
        <span class="text-base leading-none">🇨🇦</span>
        <span class="font-body text-xs font-medium text-white/80 tracking-wide">
          Canada
        </span>
      </div>
      <div class="w-1 h-1 rounded-full bg-brand-gold-500/50"></div>
      <div class="flex items-center gap-2 card-glass rounded-full px-4 py-2">
        <span class="text-brand-gold-400 text-xs font-semibold">
          Master's Only
        </span>
      </div>
    </div>

    <!-- Video Block -->
    <div
      id="hero-video-block"
      class="gsap-fade-up w-full max-w-xs sm:max-w-sm md:max-w-md
             lg:max-w-lg mt-2"
    >
      <!-- Video Thumbnail / Player -->
      <div
        id="video-trigger"
        class="relative rounded-2xl overflow-hidden cursor-pointer
               card-glass border border-brand-gold-500/20
               group transition-transform duration-500 ease-smooth
               hover:scale-[1.02] hover:border-brand-gold-500/40"
        role="button"
        aria-label="Play AdmitWithEase introduction video"
        tabindex="0"
      >
        <!-- Poster frame — dark gradient placeholder -->
        <div
          class="w-full aspect-video bg-gradient-to-br
                 from-brand-green-700 to-brand-green-900
                 flex items-center justify-center"
        >
          <!-- Play button -->
          <div
            id="play-btn"
            class="relative flex items-center justify-center
                   w-16 h-16 md:w-20 md:h-20 rounded-full
                   bg-brand-gold-500 text-brand-green-900
                   shadow-[0_0_40px_rgba(201,149,42,0.4)]
                   transition-all duration-300 ease-smooth
                   group-hover:scale-110
                   group-hover:shadow-[0_0_60px_rgba(201,149,42,0.6)]"
          >
            <!-- Pulse ring -->
            <div class="absolute inset-0 rounded-full bg-brand-gold-500/30
                        animate-ping"></div>
            <!-- Play icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="ml-1"
            >
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
          </div>

          <!-- Label below play btn -->
          <div class="absolute bottom-4 left-0 right-0 flex justify-center">
            <span class="font-body text-xs text-white/60 tracking-widest uppercase">
              Watch Our Story
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      id="hero-scroll"
      class="gsap-fade-in flex flex-col items-center gap-2 mt-2"
    >
      <span class="font-body text-[10px] text-white/30 tracking-[0.25em] uppercase">
        Scroll
      </span>
      <div class="w-[1px] h-8 bg-gradient-to-b from-brand-gold-500/60 to-transparent
                  animate-bounce"></div>
    </div>

  </div>
</section>

<!-- VIDEO LIGHTBOX -->
<div
  id="video-lightbox"
  class="fixed inset-0 z-[100] flex items-center justify-center
         bg-black/95 backdrop-blur-sm
         opacity-0 pointer-events-none"
  role="dialog"
  aria-modal="true"
  aria-label="Video player"
>
  <!-- Close button -->
  <button
    id="lightbox-close"
    aria-label="Close video"
    class="absolute top-4 right-4 md:top-6 md:right-6
           w-10 h-10 flex items-center justify-center
           rounded-full bg-white/10 text-white
           hover:bg-brand-gold-500 hover:text-brand-green-900
           transition-all duration-300 ease-smooth z-10 cursor-pointer"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
         viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <!-- Video container — preserves aspect ratio, never stretches -->
  <div
    id="lightbox-content"
    class="relative w-full max-w-[95vw] md:max-w-[85vw] lg:max-w-5xl
           mx-4 rounded-2xl overflow-hidden
           shadow-[0_0_80px_rgba(201,149,42,0.15)]
           scale-95"
  >
    <div class="relative w-full aspect-video bg-black">
      <video
        id="lightbox-video"
        src={videoUrl}
        class="absolute inset-0 w-full h-full object-contain"
        playsinline
        preload="none"
        tabindex="-1"
      ></video>
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── Hero entrance animations ──────────────────────────────
  const tl = gsap.timeline({ delay: 0.2 });

  tl.to('#hero-label', {
    opacity: 1,
    duration: 0.8,
    ease: 'power2.out',
  })
  .to('#hero-line-1 span, #hero-line-2 span, #hero-line-3 span', {
    y: 0,
    duration: 0.9,
    stagger: 0.12,
    ease: 'power4.out',
  }, '-=0.4')
  .to('#hero-sub', {
    opacity: 1,
    y: 0,
    duration: 0.7,
    ease: 'power3.out',
  }, '-=0.5')
  .to('#hero-ctas', {
    opacity: 1,
    y: 0,
    duration: 0.7,
    ease: 'power3.out',
  }, '-=0.5')
  .to('#hero-pills', {
    opacity: 1,
    y: 0,
    duration: 0.6,
    ease: 'power3.out',
  }, '-=0.4')
  .to('#hero-video-block', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    ease: 'power3.out',
  }, '-=0.4')
  .to('#hero-scroll', {
    opacity: 1,
    duration: 0.6,
    ease: 'power2.out',
  }, '-=0.3');

  // ── Video Lightbox ────────────────────────────────────────
  const videoTrigger = document.getElementById('video-trigger')!;
  const lightbox = document.getElementById('video-lightbox')!;
  const lightboxContent = document.getElementById('lightbox-content')!;
  const lightboxClose = document.getElementById('lightbox-close')!;
  const lightboxVideo = document.getElementById('lightbox-video') as HTMLVideoElement;

  const openLightbox = () => {
    lightbox.style.pointerEvents = 'auto';
    document.body.style.overflow = 'hidden';

    gsap.to(lightbox, {
      opacity: 1,
      duration: 0.35,
      ease: 'power2.out',
    });

    gsap.to(lightboxContent, {
      scale: 1,
      duration: 0.45,
      ease: 'power3.out',
      delay: 0.1,
      onComplete: () => {
        lightboxVideo.play().catch(() => {});
      },
    });
  };

  const closeLightbox = () => {
    lightboxVideo.pause();
    lightboxVideo.currentTime = 0;
    document.body.style.overflow = '';

    gsap.to(lightboxContent, {
      scale: 0.95,
      duration: 0.3,
      ease: 'power2.in',
    });

    gsap.to(lightbox, {
      opacity: 0,
      duration: 0.35,
      ease: 'power2.in',
      delay: 0.05,
      onComplete: () => {
        lightbox.style.pointerEvents = 'none';
      },
    });
  };

  // Open on click or Enter key
  videoTrigger.addEventListener('click', openLightbox);
  videoTrigger.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      openLightbox();
    }
  });

  // Close on button
  lightboxClose.addEventListener('click', closeLightbox);

  // Close on backdrop click
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
