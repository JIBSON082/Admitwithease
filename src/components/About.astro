---
---
<section id="about" class="relative py-24 sm:py-32 overflow-hidden" style="background: #0d2b1a;">
  <div class="absolute inset-0 gold-grid opacity-50 pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">

    <div class="text-center mb-16">
      <div id="about-label" class="section-label justify-center mb-4 gsap-hidden">Who We Are</div>
      <h2 id="about-heading" class="section-heading fluid-3xl gsap-hidden">
        Admission Without<br/>
        <span class="gold-text">Barriers</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <div class="space-y-6">
        <p id="about-p1" class="fluid-base text-white/70 leading-relaxed gsap-hidden">
          At <strong class="text-white">AdmitWithEase Global</strong>, we believe financial constraints
          should never be a barrier to achieving your academic dreams. We exist to make
          studying abroad — not just accessible — but <em class="text-brand-gold-400">genuinely easy.</em>
        </p>
        <p id="about-p2" class="fluid-base text-white/70 leading-relaxed gsap-hidden">
          We are exclusively focused on <strong class="text-white">Master's programs</strong> in the
          <strong class="text-white">United Kingdom and Canada</strong>. Our depth of specialisation
          means we know every step of the process — from choosing the right university to
          landing your visa.
        </p>
        <p id="about-p3" class="fluid-base text-white/70 leading-relaxed gsap-hidden">
          Every student who walks through our doors is treated like family. We don't believe
          in one-size-fits-all. Your journey is unique — and we'll treat it that way.
        </p>

        <blockquote id="about-quote" class="gsap-hidden relative pl-5 mt-8" style="border-left: 2px solid #c9952a;">
          <p class="font-dancing text-2xl sm:text-3xl text-white/90 leading-relaxed italic">
            "Your future is waiting.<br/>We'll help you get there."
          </p>
        </blockquote>

        <div id="about-cta" class="pt-4 gsap-hidden">
          <a href="#services" class="btn-primary inline-flex">Explore Our Services →</a>
        </div>
      </div>

      <div class="flex flex-col gap-4">

        <div id="about-card1" class="glass-card rounded-2xl p-6 sm:p-8 relative overflow-hidden group cursor-default gsap-hidden">
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-400 pointer-events-none" style="background: radial-gradient(ellipse at 50% 0%, rgba(201,149,42,0.08) 0%, transparent 70%);"></div>
          <div class="flex items-start gap-4 relative z-10">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(201,149,42,0.1); border: 1px solid rgba(201,149,42,0.2);">
              <span class="text-2xl">💰</span>
            </div>
            <div>
              <h3 class="font-cormorant text-xl sm:text-2xl font-semibold text-white mb-1">Study Now, Pay Later</h3>
              <p class="text-white/60 fluid-sm leading-relaxed">
                Our exclusive tuition loan means you don't need to show proof of personal funds.
                <strong class="text-brand-gold-400">Zero collateral. Zero guarantor.</strong> We secure your future, you pay as you go.
              </p>
            </div>
          </div>
          <div class="card-accent-line"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div id="about-card2" class="glass-card rounded-2xl p-5 relative overflow-hidden group cursor-default gsap-hidden">
            <div class="text-2xl mb-3">🎓</div>
            <h3 class="font-cormorant text-lg font-semibold text-white mb-1">Master's Specialists</h3>
            <p class="text-white/55 text-xs leading-relaxed">
              100% focused on Master's programs. No undergrad, no short courses. Just deep, focused expertise.
            </p>
            <div class="card-accent-line"></div>
          </div>
          <div id="about-card3" class="glass-card rounded-2xl p-5 relative overflow-hidden group cursor-default gsap-hidden">
            <div class="text-2xl mb-3">🤝</div>
            <h3 class="font-cormorant text-lg font-semibold text-white mb-1">End-to-End Support</h3>
            <p class="text-white/55 text-xs leading-relaxed">
              From choosing your course to holding your visa — we walk every step of the journey with you.
            </p>
            <div class="card-accent-line"></div>
          </div>
        </div>

        <div id="about-card4" class="glass-card rounded-2xl p-5 relative overflow-hidden group cursor-default gsap-hidden">
          <div class="flex items-center justify-around flex-wrap gap-4">
            <div class="flex items-center gap-2">
              <span class="text-2xl">🇬🇧</span>
              <div>
                <p class="text-white text-sm font-semibold">United Kingdom</p>
                <p class="text-white/40 text-xs">Master's Programs</p>
              </div>
            </div>
            <div class="w-px h-8 bg-brand-gold-500/20"></div>
            <div class="flex items-center gap-2 px-4 py-1 rounded-full" style="background:rgba(201,149,42,0.08); border:1px solid rgba(201,149,42,0.2);">
              <span class="text-brand-gold-500 text-xs font-semibold tracking-wider uppercase">Masters Only</span>
            </div>
            <div class="w-px h-8 bg-brand-gold-500/20"></div>
            <div class="flex items-center gap-2">
              <span class="text-2xl">🇨🇦</span>
              <div>
                <p class="text-white text-sm font-semibold">Canada</p>
                <p class="text-white/40 text-xs">Master's Programs</p>
              </div>
            </div>
          </div>
          <div class="card-accent-line"></div>
        </div>

      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const trigger = { trigger: '#about', start: 'top 80%' };

  gsap.to('#about-label',   { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', scrollTrigger: trigger });
  gsap.to('#about-heading', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out', scrollTrigger: trigger, delay: 0.1 });

  ['#about-p1','#about-p2','#about-p3','#about-quote','#about-cta'].forEach((id, i) => {
    gsap.to(id, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', delay: i * 0.1, scrollTrigger: trigger });
  });

  ['#about-card1','#about-card2','#about-card3','#about-card4'].forEach((id, i) => {
    gsap.to(id, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', delay: 0.2 + i * 0.12, scrollTrigger: trigger });
  });
</script>