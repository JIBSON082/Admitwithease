---
const services = [
  {
    icon: '🏛️',
    title: 'University Application',
    desc: 'We handle your entire application — from shortlisting the right universities to submitting a compelling, complete application package.',
  },
  {
    icon: '💰',
    title: 'Tuition & Living Expense Loan',
    desc: 'Our exclusive Study Now, Pay Later loan covers tuition and living costs. Zero collateral, zero guarantor — just your ambition.',
  },
  {
    icon: '📋',
    title: 'Proof of Funds Support',
    desc: 'We guide you through proof of funds documentation so your application meets every financial requirement without stress.',
  },
  {
    icon: '✈️',
    title: 'Visa Guidance',
    desc: 'UK Student Visa or Canadian Study Permit — we walk you through every requirement, document, and appointment step by step.',
  },
  {
    icon: '✍️',
    title: 'Personal Statement Support',
    desc: 'Your story told compellingly. Our experts help craft a personal statement that stands out and speaks to admissions committees.',
  },
  {
    icon: '📁',
    title: 'Documentation Support',
    desc: 'From transcripts to references and supporting letters — we ensure every document is in order, properly formatted, and submission-ready.',
  },
];
---
<section id="services" class="relative py-24 sm:py-32 overflow-hidden" style="background:#0a1f13;">
  <div class="absolute inset-0 gold-grid pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
    <div class="text-center mb-16">
      <div id="svc-label" class="section-label justify-center mb-4 gsap-hidden">What We Do</div>
      <h2 id="svc-heading" class="section-heading fluid-3xl gsap-hidden">
        Everything You Need to<br/>
        <span class="gold-text">Get Admitted</span>
      </h2>
      <p id="svc-sub" class="fluid-base text-white/60 max-w-2xl mx-auto mt-4 leading-relaxed gsap-hidden">
        From the first enquiry to the day you board your flight — we've built a complete suite of services
        to make your Master's dream a reality.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {services.map((svc, i) => (
        <div class="svc-card glass-card rounded-2xl p-6 sm:p-7 relative overflow-hidden group cursor-default gsap-hidden" data-index={i}>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-400 pointer-events-none"
            style="background: radial-gradient(ellipse at 50% 0%, rgba(201,149,42,0.07) 0%, transparent 70%);"></div>
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 relative z-10 group-hover:scale-110 transition-transform duration-300"
            style="background: rgba(201,149,42,0.1); border: 1px solid rgba(201,149,42,0.2);">
            <span class="text-2xl">{svc.icon}</span>
          </div>
          <h3 class="font-cormorant text-xl font-semibold text-white mb-2 relative z-10 group-hover:text-brand-gold-400 transition-colors duration-300">
            {svc.title}
          </h3>
          <p class="text-white/55 fluid-sm leading-relaxed relative z-10">{svc.desc}</p>
          <div class="card-accent-line"></div>
        </div>
      ))}
    </div>

    <div id="svc-cta" class="text-center mt-14 gsap-hidden">
      <a href="#contact" class="btn-primary inline-flex text-sm sm:text-base">Start Your Journey →</a>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const st = { trigger: '#services', start: 'top 80%' };

  gsap.to('#svc-label',   { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', scrollTrigger: st });
  gsap.to('#svc-heading', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out', scrollTrigger: st, delay: 0.1 });
  gsap.to('#svc-sub',     { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', scrollTrigger: st, delay: 0.2 });
  gsap.to('.svc-card',    { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', stagger: 0.1, delay: 0.3, scrollTrigger: st });
  gsap.to('#svc-cta',     { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out', scrollTrigger: st, delay: 0.9 });
</script>