---
const logoUrl = "https://res.cloudinary.com/dx3k7hbnc/image/upload/v1780761984/download_1_jmak4w.webp";

const navLinks = [
  { label: 'Home', href: '#home' },
  { label: 'About', href: '#about' },
  { label: 'Services', href: '#services' },
  { label: 'Destinations', href: '#destinations' },
  { label: 'Why Us', href: '#why-us' },
  { label: 'Testimonials', href: '#testimonials' },
  { label: 'Contact', href: '#contact' },
];

const socialLinks = [
  {
    label: 'WhatsApp',
    href: 'https://wa.me/2348142142533',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
    color: 'hover:bg-[#25D366]/15 hover:border-[#25D366]/40 hover:text-[#25D366]',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/admitwithease.global?igsh=N2RhMHFnanFyZWFx',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
    color: 'hover:bg-[#E1306C]/15 hover:border-[#E1306C]/40 hover:text-[#E1306C]',
  },
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/share/1bdnM4YE3W/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
    color: 'hover:bg-[#1877F2]/15 hover:border-[#1877F2]/40 hover:text-[#1877F2]',
  },
  {
    label: 'Email',
    href: 'mailto:admitwitheaseglobal@gmail.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    color: 'hover:bg-brand-gold-500/15 hover:border-brand-gold-500/40 hover:text-brand-gold-400',
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative w-full overflow-hidden bg-brand-green-900">

  <!-- Top divider -->
  <div
    class="absolute top-0 left-0 right-0 h-px
           bg-gradient-to-r from-transparent via-brand-gold-500/40
           to-transparent pointer-events-none"
  ></div>

  <!-- BG orb -->
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2
           w-[600px] h-[300px] rounded-full
           bg-brand-gold-500/4 blur-[120px] pointer-events-none"
  ></div>

  <!-- CTA Banner -->
  <div
    class="relative z-10 section-padding w-full
           py-14 md:py-16 border-b border-white/5"
  >
    <div
      class="max-w-4xl mx-auto flex flex-col md:flex-row
             items-center justify-between gap-8 text-center md:text-left"
    >
      <div class="flex flex-col gap-2">
        <h3
          class="font-heading text-fluid-xl text-white
                 font-semibold leading-snug"
        >
          Let's Make Your Study Abroad Dream
          <span class="font-script text-brand-gold-400 ml-2">
            a Reality!
          </span>
        </h3>
        <p class="font-body text-sm text-white/50">
          UK · Canada · Master's Programs · Tuition Loan Support
        </p>
      </div>
      <a
        href="#contact"
        class="btn-primary flex-shrink-0 text-sm px-7 py-3.5"
      >
        Get Started Today
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15" height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Main footer body -->
  <div
    class="relative z-10 section-padding w-full
           py-12 md:py-16"
  >
    <div
      class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2
             lg:grid-cols-3 gap-10 md:gap-12"
    >

      <!-- COL 1 — Brand -->
      <div class="flex flex-col gap-5 sm:col-span-2 lg:col-span-1">

        <!-- Logo + name -->
        <a href="#home" class="flex items-center gap-3 w-fit">
          <img
            src={logoUrl}
            alt="AdmitWithEase Global"
            width="44"
            height="44"
            class="w-11 h-11 object-contain rounded-full"
            loading="lazy"
            decoding="async"
          />
          <div class="flex flex-col">
            <span
              class="font-heading text-base text-white
                     font-semibold leading-tight"
            >
              AdmitWithEase
              <span class="text-brand-gold-400">Global</span>
            </span>
            <span
              class="font-body text-[10px] text-white/40
                     tracking-[0.15em] uppercase"
            >
              Study Abroad, The Easy Way
            </span>
          </div>
        </a>

        <!-- Brand description -->
        <p class="font-body text-sm text-white/50 leading-relaxed max-w-xs">
          Specialist study abroad consultancy helping Nigerian
          students gain Master's admission in the UK and Canada —
          with tuition loan support.
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-2.5">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class={`w-9 h-9 rounded-xl flex items-center justify-center
                      text-white/50 bg-white/5 border border-white/10
                      transition-all duration-300 ease-smooth
                      ${social.color}`}
              set:html={social.icon}
            >
            </a>
          ))}
        </div>

      </div>

      <!-- COL 2 — Navigation -->
      <div class="flex flex-col gap-5">
        <h4
          class="font-body text-xs text-white/40
                 tracking-[0.2em] uppercase font-medium"
        >
          Navigation
        </h4>
        <nav class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="font-body text-sm text-white/60
                     hover:text-brand-gold-400
                     transition-colors duration-300 w-fit
                     flex items-center gap-2 group"
            >
              <span
                class="w-0 h-px bg-brand-gold-500
                       group-hover:w-4 transition-all
                       duration-300 ease-smooth"
              ></span>
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- COL 3 — Contact -->
      <div class="flex flex-col gap-5">
        <h4
          class="font-body text-xs text-white/40
                 tracking-[0.2em] uppercase font-medium"
        >
          Contact Us
        </h4>
        <div class="flex flex-col gap-4">

          <!-- WhatsApp -->
          <a
            href="https://wa.me/2348142142533"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 group w-fit"
          >
            <div
              class="w-8 h-8 rounded-lg bg-[#25D366]/10
                     border border-[#25D366]/20
                     flex items-center justify-center
                     text-[#25D366] flex-shrink-0
                     group-hover:bg-[#25D366]/20
                     transition-all duration-300"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                   viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <span
              class="font-body text-sm text-white/60
                     group-hover:text-white/90
                     transition-colors duration-300"
            >
              +234 814 214 2533
            </span>
          </a>

          <!-- Email -->
          <a
            href="mailto:admitwitheaseglobal@gmail.com"
            class="flex items-center gap-3 group w-fit"
          >
            <div
              class="w-8 h-8 rounded-lg bg-brand-gold-500/10
                     border border-brand-gold-500/20
                     flex items-center justify-center
                     text-brand-gold-400 flex-shrink-0
                     group-hover:bg-brand-gold-500/20
                     transition-all duration-300"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                   viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <span
              class="font-body text-sm text-white/60
                     group-hover:text-white/90
                     transition-colors duration-300
                     break-all"
            >
              admitwitheaseglobal@gmail.com
            </span>
          </a>

          <!-- Destinations note -->
          <div
            class="flex items-center gap-3 mt-2
                   card-glass rounded-xl px-4 py-3"
          >
            <span class="text-xl leading-none">🇬🇧</span>
            <span class="text-white/30 text-xs">·</span>
            <span class="text-xl leading-none">🇨🇦</span>
            <span
              class="font-body text-xs text-white/40
                     leading-tight"
            >
              UK & Canada<br/>Master's Programs Only
            </span>
          </div>

        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div
    class="relative z-10 section-padding w-full
           py-5 border-t border-white/5"
  >
    <div
      class="max-w-6xl mx-auto flex flex-col sm:flex-row
             items-center justify-between gap-3
             text-center sm:text-left"
    >
      <p class="font-body text-xs text-white/25">
        © {currentYear} AdmitWithEase Global. All rights reserved.
      </p>
      <p class="font-body text-xs text-white/20">
        Study Abroad, The Easy Way
      </p>
    </div>
  </div>

</footer>
