---
---
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 w-full transition-all duration-300">
  <div class="relative flex items-center justify-between px-5 sm:px-8 lg:px-12 h-16 sm:h-20">

    <button id="hamburger" aria-label="Open menu" class="relative z-10 flex flex-col justify-center items-start gap-[5px] w-11 h-11 cursor-pointer">
      <span id="ham-line1" class="block h-[2px] w-6 bg-white rounded-full origin-center transition-all"></span>
      <span id="ham-line2" class="block h-[2px] w-6 bg-white rounded-full origin-center transition-all"></span>
      <span id="ham-line3" class="block h-[2px] w-4 bg-brand-gold-500 rounded-full origin-center transition-all"></span>
    </button>

    <a href="#" class="absolute left-1/2 -translate-x-1/2 z-10" aria-label="AdmitWithEase Global">
      <img
        src="https://res.cloudinary.com/dx3k7hbnc/image/upload/v1780761984/download_1_jmak4w.webp"
        alt="AdmitWithEase Global"
        class="h-10 sm:h-12 w-auto object-contain"
        loading="eager"
        decoding="async"
      />
    </a>

    <a href="#contact" class="btn-primary text-sm px-4 sm:px-6 py-2 sm:py-3 relative z-10">
      Apply Now
    </a>
  </div>
</nav>

<div id="mobile-menu" class="fixed inset-0 z-40 flex flex-col" style="background:#0a1f13; opacity:0; pointer-events:none;">
  <div class="flex items-center justify-between px-5 sm:px-8 h-16 sm:h-20 border-b border-brand-gold-500/10">
    <img
      src="https://res.cloudinary.com/dx3k7hbnc/image/upload/v1780761984/download_1_jmak4w.webp"
      alt="AdmitWithEase Global"
      class="h-10 w-auto object-contain"
      loading="lazy"
    />
    <button id="close-menu" aria-label="Close menu" class="w-11 h-11 flex items-center justify-center">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M2 2L18 18M18 2L2 18" stroke="#c9952a" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="flex-1 flex flex-col justify-center px-8 sm:px-12">
    <nav class="flex flex-col gap-1">
      {[
        { label: 'Home', href: '#' },
        { label: 'About', href: '#about' },
        { label: 'Services', href: '#services' },
        { label: 'Destinations', href: '#destinations' },
        { label: 'Why Choose Us', href: '#why' },
        { label: 'Testimonials', href: '#testimonials' },
        { label: 'Contact', href: '#contact' },
      ].map((link) => (
        <a
          href={link.href}
          class="nav-link block font-cormorant text-4xl sm:text-5xl font-light text-white hover:text-brand-gold-500 transition-colors duration-300 py-2 border-b border-white/5"
          style="opacity:0; transform:translateY(20px)"
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="mt-10">
      <a href="#contact" class="btn-primary inline-flex" style="opacity:0">Start Your Application →</a>
    </div>
  </div>

  <div class="px-8 sm:px-12 pb-8" style="opacity:0" id="menu-phone">
    <p class="text-white/40 text-xs font-inter tracking-widest uppercase mb-1">WhatsApp / Call</p>
    <a href="https://wa.me/2348142142533" class="text-brand-gold-500 font-inter text-base font-medium">+234 814 214 2533</a>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const navbar = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const closeMenu = document.getElementById('close-menu')!;
  const navLinks = mobileMenu.querySelectorAll<HTMLElement>('.nav-link');
  const menuApply = mobileMenu.querySelector<HTMLElement>('.btn-primary');
  const menuPhone = document.getElementById('menu-phone')!;

  let menuOpen = false;
  let scrolled = false;

  window.addEventListener('scroll', () => {
    const past = window.scrollY > 80;
    if (past !== scrolled) {
      scrolled = past;
      gsap.to(navbar, {
        backgroundColor: past ? 'rgba(10,31,19,0.97)' : 'rgba(10,31,19,0)',
        borderBottom: past ? '1px solid rgba(201,149,42,0.3)' : '1px solid rgba(201,149,42,0)',
        duration: 0.4,
        ease: 'power2.out',
      });
    }
  });

  function openMenu() {
    menuOpen = true;
    mobileMenu.style.pointerEvents = 'all';
    document.body.style.overflow = 'hidden';

    const tl = gsap.timeline();
    tl.to(mobileMenu, { opacity: 1, duration: 0.3, ease: 'power2.out' })
      .to(navLinks, { opacity: 1, y: 0, stagger: 0.07, duration: 0.4, ease: 'power3.out' }, '-=0.1')
      .to(menuApply, { opacity: 1, duration: 0.3, ease: 'power2.out' }, '-=0.2')
      .to(menuPhone, { opacity: 1, duration: 0.3, ease: 'power2.out' }, '-=0.2');

    gsap.to('#ham-line1', { rotate: 45, y: 7, duration: 0.3, ease: 'power2.out' });
    gsap.to('#ham-line2', { opacity: 0, duration: 0.2 });
    gsap.to('#ham-line3', { rotate: -45, y: -7, width: 24, duration: 0.3, ease: 'power2.out' });
  }

  function closeMenuFn() {
    menuOpen = false;
    document.body.style.overflow = '';

    const tl = gsap.timeline();
    tl.to([...navLinks].reverse(), { opacity: 0, y: -15, stagger: 0.04, duration: 0.25, ease: 'power2.in' })
      .to(menuApply, { opacity: 0, duration: 0.2 }, '-=0.2')
      .to(menuPhone, { opacity: 0, duration: 0.2 }, '-=0.2')
      .to(mobileMenu, { opacity: 0, duration: 0.25, ease: 'power2.in', onComplete: () => {
        mobileMenu.style.pointerEvents = 'none';
      }});

    gsap.to('#ham-line1', { rotate: 0, y: 0, duration: 0.3, ease: 'power2.out' });
    gsap.to('#ham-line2', { opacity: 1, duration: 0.3 });
    gsap.to('#ham-line3', { rotate: 0, y: 0, width: 16, duration: 0.3, ease: 'power2.out' });
  }

  hamburger.addEventListener('click', () => menuOpen ? closeMenuFn() : openMenu());
  closeMenu.addEventListener('click', closeMenuFn);
  navLinks.forEach(link => link.addEventListener('click', () => {
    closeMenuFn();
    const href = link.getAttribute('href')!;
    if (href && href !== '#') {
      const target = document.querySelector(href);
      if (target) {
        setTimeout(() => {
          const lenis = (window as any).__lenis;
          if (lenis) lenis.scrollTo(target);
        }, 350);
      }
    }
  }));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) closeMenuFn();
  });
</script>