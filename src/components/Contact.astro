---
const contactChannels = [
  {
    id: 'whatsapp',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
    label: 'WhatsApp',
    value: '+234 814 214 2533',
    href: 'https://wa.me/2348142142533',
    color: 'hover:border-[#25D366]/40 hover:bg-[#25D366]/5',
    iconColor: 'text-[#25D366]',
    action: 'Chat with us',
  },
  {
    id: 'mail',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    label: 'Email',
    value: 'admitwitheaseglobal@gmail.com',
    href: 'mailto:admitwitheaseglobal@gmail.com',
    color: 'hover:border-brand-gold-500/40 hover:bg-brand-gold-500/5',
    iconColor: 'text-brand-gold-400',
    action: 'Send an email',
  },
  {
    id: 'instagram',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
    label: 'Instagram',
    value: '@admitwithease.global',
    href: 'https://www.instagram.com/admitwithease.global?igsh=N2RhMHFnanFyZWFx',
    color: 'hover:border-[#E1306C]/40 hover:bg-[#E1306C]/5',
    iconColor: 'text-[#E1306C]',
    action: 'Follow us',
  },
  {
    id: 'facebook',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
    label: 'Facebook',
    value: 'AdmitWithEase Global',
    href: 'https://www.facebook.com/share/1bdnM4YE3W/',
    color: 'hover:border-[#1877F2]/40 hover:bg-[#1877F2]/5',
    iconColor: 'text-[#1877F2]',
    action: 'Like our page',
  },
];
---

<section
  id="contact"
  class="relative w-full section-gap overflow-hidden"
>

  <!-- BG -->
  <div class="absolute inset-0 bg-brand-green-800/40 pointer-events-none"></div>
  <div class="absolute top-0 left-0 right-0 h-px
              bg-gradient-to-r from-transparent via-brand-gold-500/30
              to-transparent pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
              w-[700px] h-[700px] rounded-full
              bg-brand-gold-500/4 blur-[180px] pointer-events-none"></div>

  <div class="relative z-10 section-padding w-full">

    <!-- Header -->
    <div class="flex flex-col items-center text-center mb-16 md:mb-20">
      <span class="section-label" id="contact-label">Get In Touch</span>
      <h2
        id="contact-heading"
        class="section-heading gsap-fade-up max-w-xs sm:max-w-lg
               md:max-w-2xl text-balance"
      >
        Ready to Start?
        <span class="gold-gradient"> Let's Talk.</span>
      </h2>
      <p
        id="contact-sub"
        class="gsap-fade-up section-subtext mt-4 text-center"
      >
        Reach out today and take the first step toward
        your UK or Canada Master's degree.
      </p>
    </div>

    <!-- Two column layout -->
    <div
      class="grid grid-cols-1 lg:grid-cols-2
             gap-10 lg:gap-16 max-w-5xl mx-auto items-start"
    >

      <!-- LEFT — Contact channels -->
      <div id="contact-channels" class="flex flex-col gap-4">

        <p
          class="gsap-fade-up font-body text-sm text-white/50
                 mb-2 tracking-wide"
        >
          Choose how you'd like to reach us:
        </p>

        {contactChannels.map((channel, i) => (
          <a
            href={channel.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`channel-card gsap-fade-up card-glass rounded-2xl
                    p-5 flex items-center gap-4
                    border border-white/5
                    transition-all duration-300 ease-smooth
                    ${channel.color} group`}
            data-index={i}
          >

            <!-- Icon -->
            <div
              class={`flex-shrink-0 w-11 h-11 rounded-xl
                      bg-white/5 border border-white/10
                      flex items-center justify-center
                      ${channel.iconColor}
                      transition-all duration-300
                      group-hover:scale-110
                      group-hover:border-current/30`}
              set:html={channel.icon}
            >
            </div>

            <!-- Text -->
            <div class="flex flex-col min-w-0 flex-1">
              <span
                class="font-body text-xs text-white/40
                       tracking-widest uppercase mb-0.5"
              >
                {channel.label}
              </span>
              <span
                class="font-body text-sm font-medium text-white/85
                       truncate group-hover:text-white
                       transition-colors duration-300"
              >
                {channel.value}
              </span>
            </div>

            <!-- Action label -->
            <span
              class="flex-shrink-0 font-body text-xs
                     text-white/30 group-hover:text-white/60
                     transition-colors duration-300 hidden sm:block"
            >
              {channel.action} →
            </span>

          </a>
        ))}

        <!-- WhatsApp quick CTA -->
        <a
          href="https://wa.me/2348142142533"
          target="_blank"
          rel="noopener noreferrer"
          class="gsap-fade-up btn-primary justify-center mt-2
                 bg-[#25D366] hover:bg-[#20bd5a] text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
               viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Chat on WhatsApp Now
        </a>

      </div>

      <!-- RIGHT — Contact form -->
      <div id="contact-form-wrap" class="gsap-fade-up">

        <div class="card-glass rounded-2xl p-6 md:p-8">

          <h3
            class="font-heading text-fluid-lg text-white
                   font-semibold mb-6"
          >
            Send Us a Message
          </h3>

          <div id="contact-form" class="flex flex-col gap-4">

            <!-- Full Name -->
            <div class="flex flex-col gap-1.5">
              <label
                for="name"
                class="font-body text-xs text-white/50
                       tracking-widest uppercase"
              >
                Full Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Your full name"
                autocomplete="name"
                class="w-full bg-white/5 border border-white/10
                       rounded-xl px-4 py-3
                       font-body text-sm text-white
                       placeholder:text-white/25
                       focus:outline-none focus:border-brand-gold-500/50
                       focus:bg-white/8
                       transition-all duration-300 ease-smooth"
              />
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-1.5">
              <label
                for="email"
                class="font-body text-xs text-white/50
                       tracking-widest uppercase"
              >
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="your@email.com"
                autocomplete="email"
                class="w-full bg-white/5 border border-white/10
                       rounded-xl px-4 py-3
                       font-body text-sm text-white
                       placeholder:text-white/25
                       focus:outline-none focus:border-brand-gold-500/50
                       focus:bg-white/8
                       transition-all duration-300 ease-smooth"
              />
            </div>

            <!-- Phone -->
            <div class="flex flex-col gap-1.5">
              <label
                for="phone"
                class="font-body text-xs text-white/50
                       tracking-widest uppercase"
              >
                Phone / WhatsApp
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="+234 000 000 0000"
                autocomplete="tel"
                class="w-full bg-white/5 border border-white/10
                       rounded-xl px-4 py-3
                       font-body text-sm text-white
                       placeholder:text-white/25
                       focus:outline-none focus:border-brand-gold-500/50
                       focus:bg-white/8
                       transition-all duration-300 ease-smooth"
              />
            </div>

            <!-- Destination -->
            <div class="flex flex-col gap-1.5">
              <label
                class="font-body text-xs text-white/50
                       tracking-widest uppercase"
              >
                Destination
              </label>
              <div class="grid grid-cols-3 gap-2">
                {['🇬🇧 UK', '🇨🇦 Canada', '🌍 Both'].map((option) => (
                  <label
                    class="dest-option flex items-center justify-center
                           gap-1.5 bg-white/5 border border-white/10
                           rounded-xl px-3 py-2.5 cursor-pointer
                           transition-all duration-300 ease-smooth
                           hover:border-brand-gold-500/40
                           has-[:checked]:border-brand-gold-500
                           has-[:checked]:bg-brand-gold-500/10"
                  >
                    <input
                      type="radio"
                      name="destination"
                      value={option}
                      class="sr-only"
                    />
                    <span class="font-body text-xs text-white/70
                                 has-[:checked]:text-brand-gold-400">
                      {option}
                    </span>
                  </label>
                ))}
              </div>
            </div>

            <!-- Message -->
            <div class="flex flex-col gap-1.5">
              <label
                for="message"
                class="font-body text-xs text-white/50
                       tracking-widest uppercase"
              >
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="3"
                placeholder="Tell us about your study goals..."
                class="w-full bg-white/5 border border-white/10
                       rounded-xl px-4 py-3
                       font-body text-sm text-white
                       placeholder:text-white/25
                       focus:outline-none focus:border-brand-gold-500/50
                       focus:bg-white/8
                       transition-all duration-300 ease-smooth
                       resize-none"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              id="form-submit"
              type="button"
              class="btn-primary justify-center w-full mt-2"
            >
              <span id="btn-text">Send Message</span>
              <svg
                id="btn-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="16" height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>

            <!-- Success message -->
            <div
              id="form-success"
              class="hidden flex items-center gap-3
                     bg-[#25D366]/10 border border-[#25D366]/30
                     rounded-xl px-4 py-3"
            >
              <span class="text-[#25D366] text-lg">✓</span>
              <p class="font-body text-sm text-white/80">
                Message sent! We'll be in touch shortly.
              </p>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── Scroll animations ─────────────────────────────────────
  gsap.from('#contact-label', {
    opacity: 0,
    y: 20,
    duration: 0.7,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#contact',
      start: 'top 80%',
    },
  });

  gsap.from('#contact-heading, #contact-sub', {
    opacity: 0,
    y: 40,
    duration: 0.9,
    stagger: 0.15,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#contact-heading',
      start: 'top 85%',
    },
  });

  gsap.from('.channel-card', {
    opacity: 0,
    x: -40,
    duration: 0.7,
    stagger: 0.1,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#contact-channels',
      start: 'top 80%',
    },
  });

  gsap.from('#contact-form-wrap', {
    opacity: 0,
    x: 40,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#contact-form-wrap',
      start: 'top 80%',
    },
  });

  // ── Form input focus animations ───────────────────────────
  const inputs = document.querySelectorAll('input, textarea');
  inputs.forEach((input) => {
    input.addEventListener('focus', () => {
      gsap.to(input, {
        scale: 1.01,
        duration: 0.2,
        ease: 'power2.out',
      });
    });
    input.addEventListener('blur', () => {
      gsap.to(input, {
        scale: 1,
        duration: 0.2,
        ease: 'power2.out',
      });
    });
  });

  // ── Form submit — opens WhatsApp with message ─────────────
  const submitBtn = document.getElementById('form-submit')!;
  const btnText = document.getElementById('btn-text')!;
  const btnIcon = document.getElementById('btn-icon')!;
  const formSuccess = document.getElementById('form-success')!;

  submitBtn.addEventListener('click', () => {
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('phone') as HTMLInputElement).value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();
    const destination = (document.querySelector('input[name="destination"]:checked') as HTMLInputElement)?.value || 'Not specified';

    if (!name || !email) {
      gsap.to('#contact-form', {
        x: -6,
        duration: 0.08,
        repeat: 5,
        yoyo: true,
        ease: 'power2.inOut',
        onComplete: () => gsap.set('#contact-form', { x: 0 }),
      });
      return;
    }

    // Build WhatsApp message
    const waMessage = encodeURIComponent(
      `Hello AdmitWithEase Global!\n\n` +
      `Name: ${name}\n` +
      `Email: ${email}\n` +
      `Phone: ${phone || 'Not provided'}\n` +
      `Destination: ${destination}\n` +
      `Message: ${message || 'I would like to enquire about your services.'}`
    );

    // Button loading state
    btnText.textContent = 'Sending...';
    gsap.to(btnIcon, { rotation: 360, duration: 0.5, ease: 'power2.out' });

    setTimeout(() => {
      // Show success
      formSuccess.classList.remove('hidden');
      formSuccess.classList.add('flex');
      btnText.textContent = 'Sent ✓';

      gsap.from(formSuccess, {
        opacity: 0,
        y: 10,
        duration: 0.4,
        ease: 'power3.out',
      });

      // Open WhatsApp
      window.open(`https://wa.me/2348142142533?text=${waMessage}`, '_blank');
    }, 600);
  });
</script>
